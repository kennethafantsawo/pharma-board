{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with role-based access control.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["uid", "email", "role"]
    },
    "Entity": {
      "title": "Entity",
      "description": "Partners, providers, or assurances.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["FOURNISSEUR", "ASSURANCE", "PARTENAIRE"] },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" },
        "status": { "type": "string", "enum": ["ACTIF", "INACTIF"] }
      },
      "required": ["name", "type", "status"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial transaction record.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date-time" },
        "type": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "entityId": { "type": "string" },
        "status": { "type": "string" },
        "reason": { "type": "string" },
        "dossiers": { "type": "number" },
        "beneficiaires": { "type": "number" }
      },
      "required": ["date", "type", "amount", "category", "description"]
    },
    "AuditLog": {
      "title": "AuditLog",
      "description": "Log of actions performed in the system.",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "action": { "type": "string" },
        "targetType": { "type": "string" },
        "targetId": { "type": "string" },
        "details": { "type": "string" },
        "previousData": { "type": "object" },
        "newData": { "type": "object" }
      },
      "required": ["timestamp", "action", "targetType", "targetId", "details"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles."
    },
    "/entities/{entityId}": {
      "schema": { "$ref": "#/entities/Entity" },
      "description": "Partners, providers, or assurances."
    },
    "/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "Financial transactions."
    },
    "/audit_logs/{logId}": {
      "schema": { "$ref": "#/entities/AuditLog" },
      "description": "Audit logs."
    }
  }
}
